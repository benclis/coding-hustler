# ==========================================
# CODING HUSTLER - ENVIRONMENT TEMPLATE
# ==========================================
# Copy this to .env and fill in your values!

# ========== APP ==========
APP_ENV=development
APP_DEBUG=True
LOG_LEVEL=INFO

# ========== DATABASE ==========
DATABASE_URL=sqlite:///./data/hustler.db

# ========== YOUTUBE API ==========
YOUTUBE_API_KEY=your_youtube_api_key_here
YOUTUBE_CHANNEL_ID=your_channel_id_here

# ========== STRIPE ==========
STRIPE_API_KEY=sk_test_your_stripe_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# ========== GUMROAD ==========
GUMROAD_API_TOKEN=your_gumroad_token_here
GUMROAD_PRODUCT_ID=your_product_id_here

# ========== DISCORD ==========
DISCORD_BOT_TOKEN=your_discord_token_here
DISCORD_SERVER_ID=your_server_id_here

# ========== GITHUB ==========
GITHUB_TOKEN=ghp_your_github_token_here
GITHUB_REPO=benclis/coding-hustler

# ========== CLAUDE API ==========
ANTHROPIC_API_KEY=sk-ant-your_claude_key_here

# ========== SUBSTACK ==========
SUBSTACK_API_KEY=your_substack_key_here
